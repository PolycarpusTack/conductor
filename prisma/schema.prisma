// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id                 String                 @id @default(cuid())
  name               String
  description        String?
  color              String                 @default("#3b82f6")
  apiKey             String?                @unique
  apiKeyHash         String?                @unique
  apiKeyPreview      String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  tasks              Task[]
  agents             Agent[]
  activities         ActivityLog[]
  modes              ProjectMode[]
  runtimes           ProjectRuntime[]
  mcpConnections     ProjectMcpConnection[]
  chainTemplates     ChainTemplate[]
  memories           AgentMemory[]
  // Automation scheduler config
  automationMode     String                 @default("manual") // manual, always, scheduled, startup
  automationSchedule String? // JSON: { startDay, startTime, endDay, endTime }
  automationPollMs   Int                    @default(10000) // poll interval in ms
  // Workspace container (nullable; backfilled)
  workspaceId        String?
  workspace          Workspace?             @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model Agent {
  id               String              @id @default(cuid())
  name             String
  emoji            String              @default("🤖")
  color            String              @default("#3b82f6")
  description      String?
  personality      String?
  apiKey           String?             @unique
  apiKeyHash       String?             @unique
  apiKeyPreview    String?
  isActive         Boolean             @default(false)
  lastSeen         DateTime?
  projectId        String
  project          Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks            Task[]
  activities       ActivityLog[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  role             String?
  capabilities     String?
  maxConcurrent    Int                 @default(1)
  supportedModes   String?
  modeInstructions String?
  runtimeId        String?
  runtime          ProjectRuntime?     @relation(fields: [runtimeId], references: [id], onDelete: SetNull)
  runtimeModel     String?
  systemPrompt     String?
  mcpConnectionIds String?
  taskSteps        TaskStep[]          @relation("TaskStepAgent")
  memories         AgentMemory[]
  // HTTP = legacy polling agent; DAEMON = launched by conductor-daemon
  invocationMode   AgentInvocationMode @default(HTTP)
}

model Task {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      TaskStatus    @default(BACKLOG)
  priority    TaskPriority  @default(MEDIUM)
  tag         String?
  notes       String?
  output      String? // Agent output/result
  projectId   String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agentId     String?
  agent       Agent?        @relation(fields: [agentId], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  startedAt   DateTime? // When agent started working
  completedAt DateTime? // When task was completed
  order            Int           @default(0)
  runtimeOverride  String?       // Per-task runtime override (claude-code | codex | copilot)
  activities       ActivityLog[]
  steps            TaskStep[]

  @@index([projectId, status])
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String // created, started, updated, completed, moved
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  agentId   String?
  agent     Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  details   String? // JSON string for additional info
  createdAt DateTime @default(now())

  @@index([projectId])
}

model ProjectMode {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  label        String
  color        String   @default("#60A5FA")
  icon         String?
  instructions String?
  createdAt    DateTime @default(now())

  @@unique([projectId, name])
}

model ProjectRuntime {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  adapter      String
  name         String
  models       String
  apiKeyEnvVar String?
  endpoint     String?
  config       String?
  available    Boolean  @default(true)
  createdAt    DateTime @default(now())
  agents       Agent[]

  @@unique([projectId, adapter, name])
}

model ProjectMcpConnection {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  type      String
  icon      String?
  endpoint  String?
  config    String?
  scopes    String?
  createdAt DateTime @default(now())
}

model ChainTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String   @default("🔗")
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  steps       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TaskStep {
  id               String          @id @default(cuid())
  taskId           String
  task             Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  order            Int
  agentId          String?
  agent            Agent?          @relation("TaskStepAgent", fields: [agentId], references: [id], onDelete: SetNull)
  humanLabel       String?
  mode             String
  instructions     String?
  autoContinue     Boolean         @default(true)
  status           String          @default("pending")
  output           String?
  error            String?
  startedAt        DateTime?
  completedAt      DateTime?
  rejectionNote    String?
  attempts         Int             @default(0)
  maxRetries       Int             @default(2)
  retryDelayMs     Int             @default(5000)
  timeoutMs        Int             @default(300000)
  leasedAt         DateTime?
  leasedBy         String?
  requiredSignOffs Int             @default(1)
  // DAG fields (coexist with linear 'order' for backward compatibility)
  nextSteps        String? // JSON: Array<{ targetStepId: string; condition?: { field, operator, value }; label?: string }>
  prevSteps        String? // JSON: Array<string> — for merge/join detection
  isParallelRoot   Boolean         @default(false)
  isMergePoint     Boolean         @default(false)
  fallbackAgentId  String?
  createdAt        DateTime        @default(now())
  executions       StepExecution[]
  reviews          StepReview[]
  artifacts        StepArtifact[]

  @@unique([taskId, order])
  @@index([taskId, status])
  @@index([agentId, status])
}

model StepExecution {
  id          String    @id @default(cuid())
  stepId      String
  step        TaskStep  @relation(fields: [stepId], references: [id], onDelete: Cascade)
  attempt     Int
  status      String    @default("running")
  output      String?
  error       String?
  tokensUsed  Int?
  cost        Float?
  durationMs  Int?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  toolCalls ToolCallTrace[]

  @@unique([stepId, attempt])
  @@index([stepId])
}

model ToolCallTrace {
  id          String        @id @default(cuid())
  executionId String
  execution   StepExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  toolName    String
  args        String? // JSON
  result      String? // truncated
  durationMs  Int?
  error       String?
  createdAt   DateTime      @default(now())
}

model StepArtifact {
  id          String   @id @default(cuid())
  stepId      String
  step        TaskStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  executionId String?
  type        String // text, code, diff, url, image, file, json, log, test_result
  label       String // human-readable name
  content     String? // inline content (text, code, JSON, diff)
  url         String? // external URL (image, file download, screenshot)
  mimeType    String? // e.g., "application/json", "image/png"
  metadata    String? // JSON — extra info
  createdAt   DateTime @default(now())
}

model StepReview {
  id           String    @id @default(cuid())
  stepId       String
  step         TaskStep  @relation(fields: [stepId], references: [id], onDelete: Cascade)
  reviewer     String
  decision     String // approved, rejected, revision_requested
  note         String?
  // Set when a later rejection/revision resets the step — these reviews
  // no longer count toward the next approval gate but remain for audit.
  supersededAt DateTime?
  createdAt    DateTime  @default(now())

  @@index([stepId, supersededAt])
}

enum TaskStatus {
  BACKLOG
  IN_PROGRESS
  WAITING
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Daemon + workspaces ──────────────────────────────────────────────────

model Workspace {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]
  daemons   Daemon[]
  skills    Skill[]
}

enum AgentInvocationMode {
  HTTP
  DAEMON
}

// Populated by conductor-daemon registrations.
model Daemon {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  hostname     String
  platform     String // "darwin" | "linux" | "win32"
  version      String
  capabilities String // JSON: { "claude-code": {version, path}, ... }
  tokenHash    String    @unique
  tokenPreview String
  lastSeenAt   DateTime?
  status       String    @default("offline") // offline | online | stale
  createdAt    DateTime  @default(now())

  @@index([workspaceId, status])
}

// ─── Skills library ───────────────────────────────────────────────────────

model Skill {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  body         String    // markdown content — the actual skill/playbook
  tags         String?   // JSON array of tags
  embedding    String?   // JSON float array on SQLite; cast to vector(1536) via raw SQL on Postgres
  sourceTaskId String?
  version      Int       @default(1)
  parentId     String?   // points to previous version's id
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([workspaceId])
}

model AgentMemory {
  id            String    @id @default(cuid())
  agentId       String
  agent         Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category      String    // fact | decision | preference | pattern
  content       String
  sourceTaskId  String?   // task that produced this memory, if any
  confidence    Float     @default(0.8)
  reinforcement Int       @default(1)
  lastAccessed  DateTime?
  embedding     String?   // JSON float array on SQLite; cast to vector(1536) via raw SQL on Postgres
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([agentId, projectId])
  @@index([projectId])
}
